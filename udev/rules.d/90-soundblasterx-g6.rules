SUBSYSTEM!="sound", GOTO="soundblaster_end"
ACTION!="change", GOTO="soundblaster_end"
KERNEL!="card*", GOTO="soundblaster_end"
SUBSYSTEMS=="usb", GOTO="soundblaster_check_usb"
SUBSYSTEMS!="usb", GOTO="soundblaster_end"

LABEL="soundblaster_check_usb"

ATTRS{idVendor}=="041e", ATTRS{idProduct}=="3256", ENV{ACP_PROFILE_SET}="sound-blaster-g6.conf"

LABEL="soundblaster_end"
